{
  "name": "panelis-php/module",
  "description": "Monitor installed Panelis packages, including versions, dependencies, and module details",
  "keywords": [
    "panelis"
  ],
  "type": "library",
  "require": {
    "illuminate/support": "^13.0",
    "filament/filament": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "Panelis\\Module\\": "src/",
      "Panelis\\Module\\Database\\Factories\\": "database/factories/",
      "Panelis\\Module\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Panelis\\Module\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Panelis\\Module\\Providers\\ModuleServiceProvider"
      ]
    },
    "panelis": {
      "plugins": [
        "Panelis\\Module\\Plugins\\ModulePlugin"
      ]
    }
  }
}
